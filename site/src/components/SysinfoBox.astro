---
---
<div class="sysinfo-box" role="complementary" aria-label="System information">
  <table class="sysinfo-table">
    <thead>
      <tr>
        <th colspan="2" class="sysinfo-title">GL1TCH &mdash; YOUR AI, YOUR TERMINAL, YOUR RULES</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td class="box-label">REPO:</td>
        <td class="box-value"><a href="https://github.com/8op-org/gl1tch" target="_blank" rel="noopener">github.com/8op-org/gl1tch</a></td>
      </tr>
      <tr>
        <td class="box-label">RUNS ON:</td>
        <td class="box-value">Linux &nbsp;&middot;&nbsp; macOS &nbsp;&middot;&nbsp; tmux required</td>
      </tr>
      <tr>
        <td class="box-label">BUILT WITH:</td>
        <td class="box-value">Go 1.21+ &nbsp;&middot;&nbsp; BubbleTea &nbsp;&middot;&nbsp; tmux</td>
      </tr>
    </tbody>
    <tfoot>
      <tr>
        <td colspan="2" class="sysinfo-hint"><span class="key-hint">[3]</span> get started &nbsp;&middot;&nbsp; <span class="key-hint">[4]</span> plugins &nbsp;&middot;&nbsp; <span class="key-hint">[8]</span> labs</td>
      </tr>
    </tfoot>
  </table>
</div>

<style>
.sysinfo-table {
  border: 1px solid var(--green);
  border-collapse: collapse;
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  min-width: 420px;
  color: var(--fg);
}
.sysinfo-table th,
.sysinfo-table td {
  padding: 4px 12px;
}
.sysinfo-title {
  color: var(--green);
  text-align: left;
  font-weight: normal;
  border-bottom: 1px solid var(--green);
  padding: 6px 12px;
  letter-spacing: 1px;
  font-size: 11px;
}
.box-label {
  color: var(--comment);
  white-space: nowrap;
  vertical-align: top;
  font-size: 11px;
  letter-spacing: 1px;
}
.box-value {
  color: var(--fg);
}
.box-value a {
  color: var(--cyan);
  text-decoration: none;
}
.box-value a:hover {
  text-decoration: underline;
}
tfoot tr:first-child td {
  border-top: 1px solid var(--border);
  padding-top: 6px;
  padding-bottom: 6px;
}
.sysinfo-hint {
  color: var(--comment);
  font-size: 11px;
}
.key-hint {
  color: var(--yellow);
}
</style>
