---
const labs = [
  {
    id: "A",
    name: "brain-ollama-e2e",
    title: "Brain Feedback Loop (Ollama E2E)",
    description: "Two-step brain test — step 1 writes a note, step 2 reads it back. Validates the brain context feedback system with a local model.",
    prereqs: ["Ollama running with `qwen2.5:latest` pulled"],
  },
  {
    id: "B",
    name: "brain-analyze-runs",
    title: "Analyze Pipeline Runs with Brain Context",
    description: "Analyzes recent GL1TCH pipeline runs and records an insight as a brain note for future reference.",
    prereqs: ["claude CLI on PATH (`claude --version`)"],
  },
  {
    id: "C",
    name: "local-code-review",
    title: "Local Code Review with Ollama",
    description: "Fetches the diff from the latest open PR in any repo, then asks a local qwen2.5 model for a concise code review. No API key needed.",
    prereqs: ["gh CLI authenticated", "gh sidecar configured", "jq sidecar configured", "Ollama with `qwen2.5:latest`"],
  },
  {
    id: "D",
    name: "brain-feedback-loop-demo",
    title: "Progressive Build with Brain Loop",
    description: "Builds a TypeScript calculator step-by-step. A local model handles the first steps; a cloud model finalizes. Demonstrates multi-model brain handoff.",
    prereqs: ["Ollama with `qwen2.5-coder:latest`", "claude CLI on PATH"],
  },
  {
    id: "E",
    name: "github-activity-digest",
    title: "GitHub Activity Digest",
    description: "Pulls issues and PRs from a repo, enriches with local analysis, then produces a structured JSON digest with summary totals and action items.",
    prereqs: ["gh CLI authenticated", "gh/jq sidecars configured", "Ollama with `qwen2.5:latest`", "claude CLI on PATH"],
  },
];
---
<div class="term-pane-header">
  <div class="tui-panel-header"><span>LABS</span></div>
</div>
<div class="term-pane" >
  <h2 class="section-header fg-green">// runnable pipeline examples //</h2>

  <!-- ─── LAB A: brain-ollama-e2e ───────────────────────────── -->
  <div style="margin-bottom:32px">
    <div class="tui-step-header"><span><span class="step-num">LAB A</span> · BRAIN FEEDBACK LOOP (OLLAMA E2E)</span></div>
    <p style="color:var(--fg);font-size:13px;line-height:1.8;margin:0 0 8px">
      Two-step brain test &mdash; step 1 writes a note, step 2 reads it back.
      Validates the brain context feedback system with a local model.
    </p>
    <p class="fg-comment" style="font-size:11px;margin-bottom:4px">// prerequisites</p>
    <p style="color:var(--fg);font-size:12px;line-height:1.8;margin-bottom:8px">
      <span class="fg-yellow">&#9658;</span> Ollama running with <span class="fg-cyan">qwen2.5:latest</span> pulled
    </p>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// yaml</pre>
    <pre class="code-block yaml-block"><code class="copy-target">name: brain-ollama-e2e
version: "1"

steps:
  - id: step-write
    plugin: ollama
    model: qwen2.5:latest
        prompt: |
      Summarize yourself in one sentence. Write the result
      as a brain note starting with: "INSIGHT:"

  - id: step-read
    plugin: ollama
    model: qwen2.5:latest
    needs: [step-write]
    prompt: |
      Reference the INSIGHT from the previous step.
      What did it say about itself?</code></pre>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// run</pre>
    <pre class="code-block bash-block"><code class="copy-target">glitch pipeline run brain-ollama-e2e</code></pre>
  </div>

  <!-- ─── LAB B: brain-analyze-runs ─────────────────────────── -->
  <div style="margin-bottom:32px">
    <div class="tui-step-header"><span><span class="step-num">LAB B</span> · ANALYZE PIPELINE RUNS WITH BRAIN CONTEXT</span></div>
    <p style="color:var(--fg);font-size:13px;line-height:1.8;margin:0 0 8px">
      Analyzes recent GL1TCH pipeline runs and records an insight as a brain note.
      Brain context is injected automatically into subsequent steps.
    </p>
    <p class="fg-comment" style="font-size:11px;margin-bottom:4px">// prerequisites</p>
    <p style="color:var(--fg);font-size:12px;line-height:1.8;margin-bottom:8px">
      <span class="fg-yellow">&#9658;</span> claude CLI on PATH (<code class="fg-cyan">claude --version</code>)
    </p>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// yaml</pre>
    <pre class="code-block yaml-block"><code class="copy-target">name: brain-analyze-runs
version: "1"

steps:
  - id: analyze
    executor: claude
    model: claude-haiku-4-5-20251001
    prompt: |
      You have context about recent pipeline runs provided above.
      Identify the most common failure patterns and record
      one actionable insight as a brain note.</code></pre>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// run</pre>
    <pre class="code-block bash-block"><code class="copy-target">glitch pipeline run brain-analyze-runs</code></pre>
  </div>

  <!-- ─── LAB C: local-code-review ──────────────────────────── -->
  <div style="margin-bottom:32px">
    <div class="tui-step-header"><span><span class="step-num">LAB C</span> · LOCAL CODE REVIEW WITH OLLAMA</span></div>
    <p style="color:var(--fg);font-size:13px;line-height:1.8;margin:0 0 8px">
      Fetches the diff from the latest open PR in any repo, then asks a local
      <span class="fg-cyan">qwen2.5</span> model for a concise code review. No API key needed.
    </p>
    <p class="fg-comment" style="font-size:11px;margin-bottom:4px">// prerequisites</p>
    <p style="color:var(--fg);font-size:12px;line-height:1.8;margin-bottom:8px">
      <span class="fg-yellow">&#9658;</span> gh CLI authenticated<br/>
      <span class="fg-yellow">&#9658;</span> gh sidecar configured<br/>
      <span class="fg-yellow">&#9658;</span> jq sidecar configured<br/>
      <span class="fg-yellow">&#9658;</span> Ollama with <span class="fg-cyan">qwen2.5:latest</span>
    </p>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// yaml</pre>
    <pre class="code-block yaml-block"><code class="copy-target">name: local-code-review
version: "1"

steps:
  - id: fetch-latest-pr
    plugin: gh
    vars:
      args: "pr list --repo &lt;owner&gt;/&lt;repo&gt; --json number,title --limit 1"

  - id: extract-pr-number
    plugin: jq
    vars:
      filter: ".[0].number"

  - id: fetch-diff
    plugin: gh
    vars:
      args: "pr diff &#123;&#123;steps.extract-pr-number.output&#125;&#125;"

  - id: review
    plugin: ollama
    model: qwen2.5:latest
    prompt: |
      Review this pull request diff concisely.
      Focus on correctness, clarity, and potential bugs.
      Diff: &#123;&#123;steps.fetch-diff.output&#125;&#125;</code></pre>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// run</pre>
    <pre class="code-block bash-block"><code class="copy-target">glitch pipeline run local-code-review</code></pre>
  </div>

  <!-- ─── LAB D: brain-feedback-loop-demo ───────────────────── -->
  <div style="margin-bottom:32px">
    <div class="tui-step-header"><span><span class="step-num">LAB D</span> · PROGRESSIVE BUILD WITH BRAIN LOOP</span></div>
    <p style="color:var(--fg);font-size:13px;line-height:1.8;margin:0 0 8px">
      Builds a TypeScript calculator step-by-step. A local model handles the first steps;
      a cloud model finalizes. Demonstrates multi-model brain handoff.
    </p>
    <p class="fg-comment" style="font-size:11px;margin-bottom:4px">// prerequisites</p>
    <p style="color:var(--fg);font-size:12px;line-height:1.8;margin-bottom:8px">
      <span class="fg-yellow">&#9658;</span> Ollama with <span class="fg-cyan">qwen2.5-coder:latest</span><br/>
      <span class="fg-yellow">&#9658;</span> claude CLI on PATH
    </p>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// yaml</pre>
    <pre class="code-block yaml-block"><code class="copy-target">name: brain-feedback-loop-demo
version: "1"

steps:
  - id: step-foundation
    plugin: ollama
    model: qwen2.5-coder:latest
        prompt: |
      Write TypeScript functions: add(a,b) and subtract(a,b).
      Include a basic test block using console.log.

  - id: step-extend
    plugin: ollama
    model: qwen2.5-coder:latest
    needs: [step-foundation]
        prompt: |
      Extend the calculator from the previous step.
      Add multiply(a,b) and divide(a,b) with division-by-zero guard.

  - id: step-finalize
    executor: claude
    model: claude-haiku-4-5-20251001
    needs: [step-extend]
    prompt: |
      Review and finalize the TypeScript calculator built so far.
      Add JSDoc comments and export all functions cleanly.</code></pre>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// run</pre>
    <pre class="code-block bash-block"><code class="copy-target">glitch pipeline run brain-feedback-loop-demo</code></pre>
  </div>

  <!-- ─── LAB E: github-activity-digest ─────────────────────── -->
  <div style="margin-bottom:32px">
    <div class="tui-step-header"><span><span class="step-num">LAB E</span> · GITHUB ACTIVITY DIGEST</span></div>
    <p style="color:var(--fg);font-size:13px;line-height:1.8;margin:0 0 8px">
      Pulls issues and PRs from a repo, enriches with local analysis, then produces a
      structured JSON digest with summary totals and action items.
    </p>
    <p class="fg-comment" style="font-size:11px;margin-bottom:4px">// prerequisites</p>
    <p style="color:var(--fg);font-size:12px;line-height:1.8;margin-bottom:8px">
      <span class="fg-yellow">&#9658;</span> gh CLI authenticated<br/>
      <span class="fg-yellow">&#9658;</span> gh/jq sidecars configured<br/>
      <span class="fg-yellow">&#9658;</span> Ollama with <span class="fg-cyan">qwen2.5:latest</span><br/>
      <span class="fg-yellow">&#9658;</span> claude CLI on PATH
    </p>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// yaml</pre>
    <pre class="code-block yaml-block"><code class="copy-target">name: github-activity-digest
version: "1"

steps:
  - id: fetch-issues
    plugin: gh
    vars:
      args: "issue list --repo &lt;owner&gt;/&lt;repo&gt; --json number,title,state --limit 20"

  - id: fetch-prs
    plugin: gh
    vars:
      args: "pr list --repo &lt;owner&gt;/&lt;repo&gt; --json number,title,state --limit 10"

  - id: local-analysis
    plugin: ollama
    model: qwen2.5:latest
    prompt: |
      Analyze these GitHub issues and PRs. Identify themes and blockers.
      Issues: &#123;&#123;steps.fetch-issues.output&#125;&#125;
      PRs: &#123;&#123;steps.fetch-prs.output&#125;&#125;

  - id: structured-digest
    executor: claude
    model: claude-haiku-4-5-20251001
    prompt: |
      Based on this analysis, produce a JSON digest with:
      - total_issues, total_prs, action_items array
      Analysis: &#123;&#123;steps.local-analysis.output&#125;&#125;</code></pre>
    <pre class="fg-comment" style="font-size:11px;margin-bottom:0">// run</pre>
    <pre class="code-block bash-block"><code class="copy-target">glitch pipeline run github-activity-digest</code></pre>
  </div>

  <!-- ─── STATUS LINE HINT ───────────────────────────────────── -->
  <p style="color:var(--comment);font-size:11px;margin-top:8px">
    <span class="fg-yellow">j/k</span> navigate &nbsp;&middot;&nbsp; <span class="fg-yellow">enter</span> run &nbsp;&middot;&nbsp; <span class="fg-yellow">esc</span> back
  </p>
</div>
