---
import { getCollection } from 'astro:content';

const entries = await getCollection('changelog');

// Sort by version descending (semver: major.minor.patch as numbers)
entries.sort((a, b) => {
  const parse = (v: string) => v.split('.').map(Number) as [number, number, number];
  const [aMaj, aMin, aPat] = parse(a.data.version);
  const [bMaj, bMin, bPat] = parse(b.data.version);
  if (bMaj !== aMaj) return bMaj - aMaj;
  if (bMin !== aMin) return bMin - aMin;
  return bPat - aPat;
});

const DIVIDER = '─'.repeat(63);

function esc(s: string): string {
  return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
}

const lines: string[] = [];
for (const entry of entries) {
  lines.push(`<span class="fg-comment">${DIVIDER}</span>`);
  const breakingBadge = entry.data.breaking
    ? ` <span class="fg-red">[BREAKING]</span>`
    : '';
  lines.push(`<span class="fg-cyan">[v${esc(entry.data.version)}]</span> <span class="fg-comment">${esc(entry.data.date)}</span>${breakingBadge}`);
  for (const h of (entry.data.highlights ?? [])) {
    lines.push(`             <span class="fg-green">&#9654; feat:</span> ${esc(h)}`);
  }
}
lines.push(`<span class="fg-comment">${DIVIDER}</span>`);

const preContent = lines.join('\n');
---
<div class="term-pane-header">
  <div class="tui-panel-header"><span>CHANGELOG</span></div>
</div>
<div class="term-pane" style="overflow-y:auto">
  <h2 class="section-header fg-yellow">// release log //</h2>

  <pre style="color:var(--fg);font-size:12px;line-height:1.8" set:html={preContent}></pre>

  <p style="color:var(--comment);font-size:11px;margin-top:4px">
    <span class="fg-yellow">&rarr;</span> Press <span class="fg-yellow">1</span> for home &nbsp;&middot;&nbsp; <span class="fg-yellow">5</span> for pipelines &nbsp;&middot;&nbsp; <span class="fg-yellow">9</span> for docs
  </p>
</div>
