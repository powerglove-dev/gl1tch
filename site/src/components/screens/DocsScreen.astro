---
import { getCollection, render } from 'astro:content';

const pipelines = await getCollection('pipelines');
const sorted = pipelines.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (doc) => {
    const { Content } = await render(doc);
    return { doc, Content, slug: doc.id.replace(/\.(md|mdx)$/, '') };
  })
);
---

<div class="ds-root">
  <div class="ds-body-wrap">

    <!-- left sidebar nav -->
    <nav class="ds-sidebar" id="ds-sidebar" aria-label="Documentation sections">
      <div class="ds-sidebar-label">docs</div>
      {rendered.map(({ doc, slug }, i) => (
        <button
          class={`ds-nav-item${i === 0 ? ' active' : ''}`}
          data-target={`ds-article-${slug}`}
          data-slug={slug}
          onclick="DS.show(this)"
        >
          <span class="ds-nav-num">{String(doc.data.order).padStart(2, '0')}</span>
          <span class="ds-nav-label">{doc.data.title}</span>
        </button>
      ))}
    </nav>

    <!-- scrollable content -->
    <div class="ds-body" id="ds-body">
      {rendered.map(({ doc, Content, slug }, i) => (
        <article
          id={`ds-article-${slug}`}
          class={`ds-article${i === 0 ? ' visible' : ''}`}
          aria-hidden={i !== 0}
        >
          <div class="ds-article-meta">
            <span class="ds-article-title fg-purple">{doc.data.title}</span>
            <span class="ds-article-desc fg-comment">{doc.data.description}</span>
          </div>
          <div class="ds-content">
            <Content />
          </div>
        </article>
      ))}
    </div>

    <!-- right table of contents -->
    <nav class="ds-toc" id="ds-toc" aria-label="Table of contents"></nav>

  </div>
</div>

<script>
  const DS = {
    show(btn: HTMLButtonElement) {
      const target = btn.dataset.target;
      if (!target) return;

      document.querySelectorAll('.ds-nav-item').forEach(el => el.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll('.ds-article').forEach(el => {
        el.classList.remove('visible');
        el.setAttribute('aria-hidden', 'true');
      });

      const article = document.getElementById(target);
      if (article) {
        article.classList.add('visible');
        article.removeAttribute('aria-hidden');
        const body = document.getElementById('ds-body');
        if (body) body.scrollTop = 0;
        this.buildToc(article);
        this.classifyAdmonitions(article);
        this.patchLinks(article);
      }
    },

    showBySlug(slug: string) {
      const btn = document.querySelector<HTMLButtonElement>(
        `.ds-nav-item[data-slug="${slug}"]`
      );
      if (btn) this.show(btn);
    },

    buildToc(article: HTMLElement) {
      const toc = document.getElementById('ds-toc');
      if (!toc) return;
      const headings = article.querySelectorAll<HTMLHeadingElement>('h2, h3');
      toc.replaceChildren();
      if (headings.length < 2) {
        toc.style.display = 'none';
        return;
      }
      toc.style.display = '';

      const label = document.createElement('div');
      label.className = 'toc-label';
      label.textContent = 'contents';
      toc.appendChild(label);

      headings.forEach(h => {
        if (!h.id) {
          h.id = (h.textContent ?? '').trim().toLowerCase().replace(/[^\w]+/g, '-');
        }
        const a = document.createElement('a');
        a.href = '#' + h.id;
        a.textContent = h.textContent ?? '';
        a.className = 'toc-link toc-' + h.tagName.toLowerCase();
        a.addEventListener('click', (e) => {
          e.preventDefault();
          h.scrollIntoView({ behavior: 'smooth', block: 'start' });
          toc.querySelectorAll('.toc-link').forEach(l => l.classList.remove('active'));
          a.classList.add('active');
        });
        toc.appendChild(a);
      });

      const body = document.getElementById('ds-body');
      if (!body) return;
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const id = entry.target.id;
            toc.querySelectorAll('.toc-link').forEach(l => {
              l.classList.toggle('active', (l as HTMLAnchorElement).hash === '#' + id);
            });
          }
        });
      }, { root: body, rootMargin: '-10% 0px -70% 0px', threshold: 0 });

      headings.forEach(h => observer.observe(h));
    },

    classifyAdmonitions(article: HTMLElement) {
      article.querySelectorAll<HTMLElement>('.ds-content blockquote').forEach(bq => {
        const strong =
          bq.querySelector<HTMLElement>('p > strong:first-child') ??
          bq.querySelector<HTMLElement>('strong:first-child');
        if (!strong) return;
        const key = (strong.textContent ?? '').trim().toUpperCase().replace(/:$/, '');
        bq.classList.remove('adm-note', 'adm-warning', 'adm-danger', 'adm-tip');
        if (['NOTE', 'INFO'].includes(key))          bq.classList.add('adm-note');
        else if (['WARNING', 'WARN'].includes(key))  bq.classList.add('adm-warning');
        else if (['DANGER', 'ERROR'].includes(key))  bq.classList.add('adm-danger');
        else if (['TIP', 'HINT'].includes(key))      bq.classList.add('adm-tip');
      });
    },

    // Intercept internal /docs/pipelines/<slug> links and switch tabs instead of navigating
    patchLinks(article: HTMLElement) {
      article.querySelectorAll<HTMLAnchorElement>('.ds-content a[href]').forEach(a => {
        const href = a.getAttribute('href') ?? '';
        const match = href.match(/^\/docs\/pipelines\/([^/#?]+)/);
        if (!match) return;
        const slug = match[1];
        // Only patch once
        if (a.dataset.patched) return;
        a.dataset.patched = '1';
        a.addEventListener('click', (e) => {
          const btn = document.querySelector<HTMLButtonElement>(
            `.ds-nav-item[data-slug="${slug}"]`
          );
          if (btn) {
            e.preventDefault();
            DS.show(btn);
          }
        });
      });
    },

    init() {
      const first = document.querySelector<HTMLElement>('.ds-article.visible');
      if (first) {
        this.buildToc(first);
        this.classifyAdmonitions(first);
        this.patchLinks(first);
      }
      // Patch all articles upfront so links work before a tab is explicitly switched
      document.querySelectorAll<HTMLElement>('.ds-article').forEach(a => this.patchLinks(a));
    },
  };

  (window as any).DS = DS;
  DS.init();
</script>

<style is:global>
.ds-root {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}

/* ── outer wrapper ── */
.ds-body-wrap {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ── left sidebar nav ── */
.ds-sidebar {
  width: 190px;
  flex-shrink: 0;
  overflow-y: auto;
  overflow-x: hidden;
  border-right: 1px solid var(--current-line);
  padding: 16px 0 40px;
  background: var(--darkbg);
  scrollbar-width: none;
}
.ds-sidebar::-webkit-scrollbar { display: none; }

.ds-sidebar-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--comment);
  opacity: 0.45;
  padding: 0 14px 12px;
}

.ds-nav-item {
  display: flex;
  align-items: baseline;
  gap: 8px;
  width: 100%;
  background: none;
  border: none;
  border-left: 2px solid transparent;
  color: var(--comment);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  padding: 6px 14px;
  cursor: pointer;
  text-align: left;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  transition: color 0.1s, border-color 0.1s, background 0.1s;
  line-height: 1.4;
}
.ds-nav-item:hover {
  color: var(--fg);
  background: rgba(255,255,255,0.03);
}
.ds-nav-item.active {
  color: var(--fg);
  border-left-color: var(--purple);
  background: rgba(189,147,249,0.07);
}

.ds-nav-num {
  font-size: 9px;
  color: var(--comment);
  opacity: 0.5;
  flex-shrink: 0;
  font-variant-numeric: tabular-nums;
}
.ds-nav-item.active .ds-nav-num { opacity: 1; color: var(--purple); }

.ds-nav-label {
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ── scrollable content ── */
.ds-body {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
  min-width: 0;
}
.ds-body::-webkit-scrollbar       { width: 3px; }
.ds-body::-webkit-scrollbar-track { background: transparent; }
.ds-body::-webkit-scrollbar-thumb { background: var(--comment); }

/* ── right table of contents ── */
.ds-toc {
  display: flex;
  flex-direction: column;
  width: 158px;
  flex-shrink: 0;
  overflow-y: auto;
  overflow-x: hidden;
  border-left: 1px solid var(--current-line);
  padding: 20px 0 40px;
  scrollbar-width: none;
}
.ds-toc::-webkit-scrollbar { display: none; }

.toc-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--comment);
  padding: 0 14px 10px;
  opacity: 0.45;
}

.toc-link {
  display: block;
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  line-height: 1.5;
  color: var(--comment);
  text-decoration: none;
  padding: 4px 14px;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  border-left: 2px solid transparent;
  transition: color 0.1s, border-color 0.1s;
}
.toc-link:hover { color: var(--fg); }
.toc-link.active {
  color: var(--purple);
  border-left-color: var(--purple);
}
.toc-h3 {
  font-size: 9.5px;
  padding: 4px 14px 4px 22px;
}

/* ── articles ── */
.ds-article {
  display: none;
  padding: 24px 32px 60px;
  max-width: 760px;
  margin: 0 auto;
}
.ds-article.visible { display: block; }

.ds-article-meta {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--current-line);
  flex-wrap: wrap;
}
.ds-article-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  letter-spacing: 0.02em;
}
.ds-article-desc {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  line-height: 1.6;
}

/* ── prose ── */
.ds-content {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  line-height: 1.9;
  color: var(--fg);
}

.ds-content h2 {
  color: var(--cyan);
  font-size: 10.5px;
  font-weight: normal;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin: 40px 0 16px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--current-line);
  display: flex;
  align-items: center;
  gap: 6px;
}
.ds-content h2::before { content: '//'; color: var(--comment); font-size: 9px; }

.ds-content h3 {
  color: var(--yellow);
  font-size: 11.5px;
  font-weight: normal;
  margin: 28px 0 10px;
  padding-left: 8px;
  border-left: 2px solid var(--yellow);
}

.ds-content h4 {
  color: var(--fg);
  font-size: 11px;
  font-weight: bold;
  margin: 18px 0 6px;
  letter-spacing: 0.04em;
}

.ds-content p { margin: 0 0 20px; }

.ds-content ul, .ds-content ol { margin: 0 0 14px; padding-left: 18px; }
.ds-content li { margin-bottom: 6px; line-height: 1.8; }
.ds-content li > p { margin-bottom: 4px; }
.ds-content ul li::marker { color: var(--purple); }
.ds-content ol li::marker { color: var(--comment); }

.ds-content code {
  background: rgba(135,135,175,0.12);
  color: var(--cyan);
  padding: 1px 5px;
  font-size: 11px;
  font-family: 'JetBrains Mono', monospace;
  border: 1px solid rgba(135,135,175,0.18);
  border-radius: 2px;
}

/* ── code blocks (Shiki syntax highlighting) ── */
.ds-content pre {
  border-left: 2px solid var(--purple);
  padding: 12px 14px;
  overflow-x: auto;
  margin: 4px 0 18px;
  font-size: 11px;
  line-height: 1.7;
}
.ds-content pre.astro-code,
.ds-content .astro-code {
  background: var(--darkbg) !important;
}
.ds-content pre code {
  background: none;
  border: none;
  padding: 0;
  font-size: inherit;
}

.ds-content strong { color: var(--fg); font-weight: bold; }
.ds-content em     { color: var(--comment); font-style: normal; }

.ds-content a {
  color: var(--purple);
  text-decoration: none;
  border-bottom: 1px solid rgba(135,135,175,0.3);
  cursor: pointer;
}
.ds-content a:hover { color: var(--cyan); border-bottom-color: var(--cyan); }

/* ── tables ── */
.ds-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 4px 0 20px;
  font-size: 11px;
  border: 1px solid var(--current-line);
}
.ds-content thead { background: var(--darkbg); border-bottom: 1px solid var(--purple); }
.ds-content th {
  color: var(--purple);
  text-align: left;
  padding: 6px 12px;
  font-weight: normal;
  letter-spacing: 0.06em;
  font-size: 10px;
  text-transform: uppercase;
  border-right: 1px solid var(--current-line);
  white-space: nowrap;
}
.ds-content th:last-child { border-right: none; }
.ds-content td {
  padding: 7px 12px;
  border-bottom: 1px solid var(--current-line);
  border-right: 1px solid var(--current-line);
  vertical-align: top;
  line-height: 1.6;
}
.ds-content td:last-child { border-right: none; }
.ds-content tr:last-child td { border-bottom: none; }
.ds-content tbody tr:nth-child(even) { background: rgba(255,255,255,0.02); }
.ds-content tbody tr:hover { background: rgba(135,135,175,0.06); }

/* ── admonitions ── */
.ds-content blockquote {
  border-left: 2px solid var(--comment);
  margin: 4px 0 18px;
  padding: 10px 14px;
  background: rgba(95,95,135,0.08);
  color: var(--fg);
  line-height: 1.8;
}
.ds-content blockquote p { margin: 0; }

.ds-content blockquote.adm-note {
  border-left-color: var(--cyan);
  background: rgba(139,233,253,0.06);
}
.ds-content blockquote.adm-note strong:first-child { color: var(--cyan); }

.ds-content blockquote.adm-tip {
  border-left-color: var(--green);
  background: rgba(80,200,120,0.06);
}
.ds-content blockquote.adm-tip strong:first-child { color: var(--green); }

.ds-content blockquote.adm-warning {
  border-left-color: var(--yellow);
  background: rgba(241,250,140,0.05);
}
.ds-content blockquote.adm-warning strong:first-child { color: var(--yellow); }

.ds-content blockquote.adm-danger {
  border-left-color: var(--red);
  background: rgba(255,85,85,0.06);
}
.ds-content blockquote.adm-danger strong:first-child { color: var(--red); }

.ds-content hr {
  border: none;
  border-top: 1px solid var(--current-line);
  margin: 24px 0;
}
</style>
