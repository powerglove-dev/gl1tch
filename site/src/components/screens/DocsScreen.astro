---
import { getCollection, render } from 'astro:content';

const pipelines = await getCollection('pipelines');
const sorted = pipelines.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (doc) => {
    const { Content } = await render(doc);
    return { doc, Content, slug: doc.id.replace(/\.(md|mdx)$/, '') };
  })
);
---

<div class="ds-root">
  <!-- compact top nav -->
  <nav class="ds-nav" id="ds-nav">
    {rendered.map(({ doc, slug }, i) => (
      <button
        class={`ds-tab${i === 0 ? ' active' : ''}`}
        data-target={`ds-article-${slug}`}
        onclick="DS.show(this)"
      >
        <span class="ds-num">{String(doc.data.order).padStart(2, '0')}</span>
        <span class="ds-label">{doc.data.title}</span>
      </button>
    ))}
  </nav>

  <!-- content -->
  <div class="ds-body" id="ds-body">
    {rendered.map(({ doc, Content, slug }, i) => (
      <article
        id={`ds-article-${slug}`}
        class={`ds-article${i === 0 ? ' visible' : ''}`}
        aria-hidden={i !== 0}
      >
        <div class="ds-article-meta">
          <span class="ds-article-title fg-purple">{doc.data.title}</span>
          <span class="ds-article-desc fg-comment">{doc.data.description}</span>
        </div>
        <div class="ds-content">
          <Content />
        </div>
      </article>
    ))}
  </div>
</div>

<script>
  const DS = {
    show(btn: HTMLButtonElement) {
      const target = btn.dataset.target;
      if (!target) return;

      document.querySelectorAll('.ds-tab').forEach(el => el.classList.remove('active'));
      btn.classList.add('active');

      document.querySelectorAll('.ds-article').forEach(el => {
        el.classList.remove('visible');
        el.setAttribute('aria-hidden', 'true');
      });

      const article = document.getElementById(target);
      if (article) {
        article.classList.add('visible');
        article.removeAttribute('aria-hidden');
        const body = document.getElementById('ds-body');
        if (body) body.scrollTop = 0;
      }
    }
  };

  (window as any).DS = DS;
</script>

<style>
.ds-root {
  display: flex;
  flex-direction: column;
  height: 100%;
  overflow: hidden;
}

/* ── top nav strip ── */
.ds-nav {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: auto;
  overflow-y: hidden;
  flex-shrink: 0;
  border-bottom: 1px solid var(--current-line);
  background: var(--darkbg);
  gap: 0;
  scrollbar-width: none;
}
.ds-nav::-webkit-scrollbar { display: none; }

.ds-tab {
  display: flex;
  align-items: center;
  gap: 5px;
  flex-shrink: 0;
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--comment);
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
  padding: 8px 14px;
  cursor: pointer;
  white-space: nowrap;
  transition: color 0.1s, border-color 0.1s;
  line-height: 1;
}
.ds-tab:hover { color: var(--fg); }
.ds-tab.active {
  color: var(--fg);
  border-bottom-color: var(--purple);
}

.ds-num {
  color: var(--comment);
  font-size: 9px;
  opacity: 0.6;
}
.ds-tab.active .ds-num { opacity: 1; }

/* ── scrollable content area ── */
.ds-body {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
}
.ds-body::-webkit-scrollbar       { width: 3px; }
.ds-body::-webkit-scrollbar-track { background: transparent; }
.ds-body::-webkit-scrollbar-thumb { background: var(--comment); }

.ds-article {
  display: none;
  padding: 20px 28px 40px;
}
.ds-article.visible { display: block; }

.ds-article-meta {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 20px;
  padding-bottom: 12px;
  border-bottom: 1px solid var(--current-line);
  flex-wrap: wrap;
}
.ds-article-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px;
  letter-spacing: 0.02em;
}
.ds-article-desc {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  line-height: 1.6;
}

/* ── prose ── */
.ds-content {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  line-height: 1.9;
  color: var(--fg);
}

.ds-content h2 {
  color: var(--cyan);
  font-size: 10.5px;
  font-weight: normal;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin: 32px 0 12px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--current-line);
  display: flex;
  align-items: center;
  gap: 6px;
}
.ds-content h2::before { content: '//'; color: var(--comment); font-size: 9px; }

.ds-content h3 {
  color: var(--yellow);
  font-size: 11.5px;
  font-weight: normal;
  margin: 24px 0 8px;
  padding-left: 8px;
  border-left: 2px solid var(--yellow);
}

.ds-content h4 {
  color: var(--fg);
  font-size: 11px;
  font-weight: bold;
  margin: 18px 0 6px;
  letter-spacing: 0.04em;
}

.ds-content p { margin: 0 0 14px; }

.ds-content ul, .ds-content ol { margin: 0 0 14px; padding-left: 18px; }
.ds-content li { margin-bottom: 6px; line-height: 1.8; }
.ds-content li > p { margin-bottom: 4px; }
.ds-content ul li::marker { color: var(--purple); }
.ds-content ol li::marker { color: var(--comment); }

.ds-content code {
  background: rgba(135,135,175,0.12);
  color: var(--cyan);
  padding: 1px 5px;
  font-size: 11px;
  font-family: 'JetBrains Mono', monospace;
  border: 1px solid rgba(135,135,175,0.18);
  border-radius: 2px;
}

.ds-content pre {
  background: var(--darkbg);
  border-left: 2px solid var(--purple);
  padding: 12px 14px;
  overflow-x: auto;
  margin: 4px 0 18px;
  font-size: 11px;
  line-height: 1.7;
}
.ds-content pre code {
  background: none;
  border: none;
  padding: 0;
  color: var(--fg);
  font-size: inherit;
}

.ds-content strong { color: var(--fg); font-weight: bold; }
.ds-content em     { color: var(--comment); font-style: normal; }

.ds-content a {
  color: var(--purple);
  text-decoration: none;
  border-bottom: 1px solid rgba(135,135,175,0.3);
}
.ds-content a:hover { color: var(--cyan); border-bottom-color: var(--cyan); }

.ds-content table {
  width: 100%;
  border-collapse: collapse;
  margin: 4px 0 20px;
  font-size: 11px;
  border: 1px solid var(--current-line);
}
.ds-content thead { background: var(--darkbg); border-bottom: 1px solid var(--purple); }
.ds-content th {
  color: var(--purple);
  text-align: left;
  padding: 6px 12px;
  font-weight: normal;
  letter-spacing: 0.06em;
  font-size: 10px;
  text-transform: uppercase;
  border-right: 1px solid var(--current-line);
  white-space: nowrap;
}
.ds-content th:last-child { border-right: none; }
.ds-content td {
  padding: 7px 12px;
  border-bottom: 1px solid var(--current-line);
  border-right: 1px solid var(--current-line);
  vertical-align: top;
  line-height: 1.6;
}
.ds-content td:last-child { border-right: none; }
.ds-content tr:last-child td { border-bottom: none; }
.ds-content tbody tr:nth-child(even) { background: rgba(255,255,255,0.02); }
.ds-content tbody tr:hover { background: rgba(135,135,175,0.06); }

.ds-content blockquote {
  border-left: 2px solid var(--comment);
  margin: 4px 0 18px;
  padding: 10px 14px;
  background: rgba(95,95,135,0.08);
  color: var(--fg);
  line-height: 1.8;
}
.ds-content blockquote p { margin: 0; }
.ds-content blockquote:has(strong:first-child) {
  border-left-color: var(--cyan);
  background: rgba(135,175,175,0.07);
}

.ds-content hr {
  border: none;
  border-top: 1px solid var(--current-line);
  margin: 24px 0;
}
</style>
