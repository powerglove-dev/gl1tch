---
import { getCollection, render } from 'astro:content';

const pipelines = await getCollection('pipelines');
const sorted = pipelines.sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  sorted.map(async (doc) => {
    const { Content } = await render(doc);
    return { doc, Content, slug: doc.id.replace(/\.(md|mdx)$/, '') };
  })
);
---

<div class="dp-shell">
  <!-- sidebar nav -->
  <nav class="dp-nav" id="dp-nav">
    <div class="dp-nav-header">
      <span class="fg-purple">GL1TCH</span><span class="fg-comment"> / docs</span>
    </div>

    <div class="dp-nav-section">PIPELINES</div>
    {rendered.map(({ doc, slug }, i) => (
      <button
        class={`dp-nav-item${i === 0 ? ' active' : ''}`}
        data-target={`dp-section-${slug}`}
        onclick="DPNav.show(this)"
      >
        <span class="dp-nav-num fg-comment">{String(doc.data.order).padStart(2, '0')}</span>
        <span class="dp-nav-label">{doc.data.title}</span>
      </button>
    ))}
  </nav>

  <!-- content panes -->
  <div class="dp-content" id="dp-content">
    {rendered.map(({ doc, Content, slug }, i) => (
      <article
        id={`dp-section-${slug}`}
        class={`dp-article${i === 0 ? ' visible' : ''}`}
        aria-hidden={i !== 0}
      >
        <div class="dp-article-header">
          <h1 class="dp-title fg-purple">{doc.data.title}</h1>
          <p class="dp-desc fg-comment">{doc.data.description}</p>
        </div>
        <div class="dp-body">
          <Content />
        </div>
      </article>
    ))}
  </div>
</div>

<script>
  const DPNav = {
    show(btn: HTMLButtonElement) {
      const target = btn.dataset.target;
      if (!target) return;

      // deactivate all nav items
      document.querySelectorAll('.dp-nav-item').forEach(el => el.classList.remove('active'));
      btn.classList.add('active');

      // hide all articles
      document.querySelectorAll('.dp-article').forEach(el => {
        el.classList.remove('visible');
        el.setAttribute('aria-hidden', 'true');
      });

      // show target
      const article = document.getElementById(target);
      if (article) {
        article.classList.add('visible');
        article.removeAttribute('aria-hidden');
        // scroll content pane to top
        const pane = document.getElementById('dp-content');
        if (pane) pane.scrollTop = 0;
      }
    }
  };

  // expose for inline onclick
  (window as any).DPNav = DPNav;
</script>

<style>
/* ── Shell layout ── */
.dp-shell {
  display: flex;
  height: 100%;
  overflow: hidden;
}

/* ── Sidebar nav ── */
.dp-nav {
  width: 168px;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  border-right: 1px solid var(--current-line);
  background: var(--darkbg);
  overflow-y: auto;
  padding: 12px 0 8px;
}

.dp-nav-header {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  padding: 0 12px 10px;
  border-bottom: 1px solid var(--current-line);
  margin-bottom: 8px;
  letter-spacing: 0.02em;
}

.dp-nav-section {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px;
  letter-spacing: 0.12em;
  color: var(--comment);
  padding: 8px 12px 4px;
  text-transform: uppercase;
}

.dp-nav-item {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  width: 100%;
  background: none;
  border: none;
  border-left: 2px solid transparent;
  color: var(--comment);
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  text-align: left;
  padding: 6px 10px 6px 10px;
  cursor: pointer;
  line-height: 1.4;
  transition: color 0.1s, border-color 0.1s;
}

.dp-nav-item:hover {
  color: var(--fg);
}

.dp-nav-item.active {
  color: var(--fg);
  border-left-color: var(--purple);
  background: rgba(135,135,175,0.06);
}

.dp-nav-num {
  font-size: 9px;
  margin-top: 1px;
  flex-shrink: 0;
}

/* ── Content pane ── */
.dp-content {
  flex: 1;
  overflow-y: auto;
  overflow-x: hidden;
}

.dp-article {
  display: none;
  padding: 28px 32px 48px;
}

.dp-article.visible {
  display: block;
}

.dp-article-header {
  border-bottom: 1px solid var(--current-line);
  padding-bottom: 16px;
  margin-bottom: 28px;
}

.dp-title {
  font-family: 'JetBrains Mono', monospace;
  font-size: 18px;
  font-weight: normal;
  margin: 0 0 8px;
  letter-spacing: 0.02em;
}

.dp-desc {
  font-size: 12px;
  margin: 0;
  line-height: 1.7;
  font-family: 'JetBrains Mono', monospace;
  color: var(--comment);
}

/* ── Markdown prose in panel ── */
.dp-body {
  font-family: 'JetBrains Mono', monospace;
  font-size: 12.5px;
  line-height: 2;
  color: var(--fg);
}

/* Headings */
.dp-body h2 {
  color: var(--cyan);
  font-size: 11px;
  font-weight: normal;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin: 36px 0 14px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--current-line);
  display: flex;
  align-items: center;
  gap: 8px;
}
.dp-body h2::before {
  content: '//';
  color: var(--comment);
  font-size: 10px;
  letter-spacing: 0;
}

.dp-body h3 {
  color: var(--yellow);
  font-size: 12px;
  font-weight: normal;
  margin: 28px 0 10px;
  padding-left: 10px;
  border-left: 2px solid var(--yellow);
}

.dp-body h4 {
  color: var(--fg);
  font-size: 11px;
  font-weight: bold;
  margin: 20px 0 8px;
  letter-spacing: 0.04em;
}

/* Paragraphs */
.dp-body p {
  margin: 0 0 18px;
  color: var(--fg);
}

/* Lists */
.dp-body ul, .dp-body ol {
  margin: 0 0 18px;
  padding-left: 20px;
}
.dp-body li {
  margin-bottom: 8px;
  line-height: 1.9;
}
.dp-body li > p { margin-bottom: 6px; }
.dp-body ul li::marker { color: var(--purple); }
.dp-body ol li::marker { color: var(--comment); }

/* Inline code */
.dp-body code {
  background: rgba(135,135,175,0.12);
  color: var(--cyan);
  padding: 2px 6px;
  font-size: 11.5px;
  font-family: 'JetBrains Mono', monospace;
  border: 1px solid rgba(135,135,175,0.18);
  border-radius: 2px;
}

/* Code blocks */
.dp-body pre {
  background: var(--darkbg);
  border-left: 3px solid var(--purple);
  padding: 16px 18px;
  overflow-x: auto;
  margin: 4px 0 22px;
  font-size: 11.5px;
  line-height: 1.75;
}
.dp-body pre code {
  background: none;
  border: none;
  padding: 0;
  color: var(--fg);
  font-size: inherit;
}

/* Strong / em */
.dp-body strong {
  color: var(--fg);
  font-weight: bold;
}
.dp-body em {
  color: var(--comment);
  font-style: normal;
}

/* Links */
.dp-body a {
  color: var(--purple);
  text-decoration: none;
  border-bottom: 1px solid rgba(135,135,175,0.3);
}
.dp-body a:hover {
  color: var(--cyan);
  border-bottom-color: var(--cyan);
}

/* Tables */
.dp-body table {
  width: 100%;
  border-collapse: collapse;
  margin: 4px 0 24px;
  font-size: 11.5px;
  border: 1px solid var(--current-line);
}
.dp-body thead {
  background: var(--darkbg);
  border-bottom: 2px solid var(--purple);
}
.dp-body th {
  color: var(--purple);
  text-align: left;
  padding: 8px 14px;
  font-weight: normal;
  letter-spacing: 0.06em;
  font-size: 10.5px;
  text-transform: uppercase;
  border-right: 1px solid var(--current-line);
  white-space: nowrap;
}
.dp-body th:last-child { border-right: none; }
.dp-body td {
  padding: 9px 14px;
  border-bottom: 1px solid var(--current-line);
  border-right: 1px solid var(--current-line);
  vertical-align: top;
  line-height: 1.7;
}
.dp-body td:last-child { border-right: none; }
.dp-body tr:last-child td { border-bottom: none; }
.dp-body tbody tr:nth-child(even) { background: rgba(255,255,255,0.02); }
.dp-body tbody tr:hover { background: rgba(135,135,175,0.06); }
.dp-body td code, .dp-body th code { font-size: 11px; }

/* Blockquotes — used as admonitions */
.dp-body blockquote {
  border-left: 3px solid var(--comment);
  margin: 4px 0 22px;
  padding: 12px 16px;
  background: rgba(95,95,135,0.08);
  color: var(--fg);
  line-height: 1.8;
}
.dp-body blockquote p { margin: 0; }
.dp-body blockquote p + p { margin-top: 8px; }

/* Admonition variants via strong prefix */
/* > **Note:** text  → blue-ish */
.dp-body blockquote:has(strong:first-child) {
  border-left-color: var(--cyan);
  background: rgba(135,175,175,0.07);
}
/* > **Warning:** text → yellow */
.dp-body blockquote:has(strong:first-child):has([data-warn]) {
  border-left-color: var(--yellow);
  background: rgba(215,175,95,0.07);
}

/* Horizontal rule as section divider */
.dp-body hr {
  border: none;
  border-top: 1px solid var(--current-line);
  margin: 28px 0;
}

/* Scrollbar inside content */
.dp-content::-webkit-scrollbar         { width: 4px; }
.dp-content::-webkit-scrollbar-track   { background: transparent; }
.dp-content::-webkit-scrollbar-thumb   { background: var(--comment); }
</style>
