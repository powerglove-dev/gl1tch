---
---
<div class="tui-terminal" id="mac-terminal">
  <!-- Left pane border accent -->
  <div class="tui-pane-bar" aria-hidden="true"></div>

  <!-- Main content area -->
  <div class="tui-main">

    <!-- Logo area -->
    <div class="tui-logo-area">
      <img src="/glitch-logo.gif" alt="GL1TCH" class="tui-logo" />
    </div>

    <!-- Output area (typewriter responses appear here) -->
    <div class="terminal-output" id="terminal-output"></div>

    <!-- Bottom bars, pinned -->
    <div class="tui-bottom">

      <!-- Status bar -->
      <div class="tui-statusbar">
        <span class="tui-status-left">&gt;&gt; GL1TCH AI assistant &nbsp;//&nbsp; Ollama</span>
        <span class="tui-status-center">&#x21BB; 3 &middot; Lv6 &middot; 8.0kxp</span>
        <span class="tui-status-right" id="tui-clock"></span>
      </div>

      <!-- Input row -->
      <div class="tui-input-row">
        <span class="tui-prompt">&gt;&gt; </span>
        <input
          type="text"
          id="terminal-input"
          autocomplete="off"
          autocorrect="off"
          autocapitalize="none"
          spellcheck="false"
          placeholder="ask glitch anything…"
          aria-label="GLITCH terminal input"
        />
      </div>

      <!-- Hint bar -->
      <div class="tui-hintbar">
        <span class="tui-hintbar-left">
          <kbd>enter</kbd><span class="tui-hint-dim"> send &middot; </span>
          <kbd>esc</kbd><span class="tui-hint-dim"> unfocus &middot; </span>
          <kbd>/help</kbd><span class="tui-hint-dim"> commands</span>
        </span>
        <span class="tui-hintbar-right tui-hint-dim">~/Projects/gl1tch</span>
      </div>

      <!-- Sessions bar -->
      <div class="tui-sessionsbar">
        <span class="tui-hint-dim">sessions: </span>
        <span class="tui-session-active">&#x25BA; main</span>
      </div>

      <!-- Chord bar -->
      <div class="tui-chordbar">
        <kbd>^spc d</kbd><span class="tui-hint-dim"> detach &nbsp;&middot;&nbsp; </span>
        <kbd>^spc r</kbd><span class="tui-hint-dim"> reload &nbsp;&middot;&nbsp; </span>
        <kbd>/quit</kbd><span class="tui-hint-dim"> quit</span>
      </div>

    </div><!-- /.tui-bottom -->
  </div><!-- /.tui-main -->
</div><!-- /.tui-terminal -->

<script>
import Fuse from 'fuse.js';

interface QAEntry {
  question: string;
  keywords: string[];
  response: string;
}

interface GlitchDB {
  commands: Record<string, string>;
  qa: QAEntry[];
}

let db: GlitchDB | null = null;
let fuse: Fuse<QAEntry> | null = null;
const history: string[] = [];
let historyIdx = -1;

const inputEl  = document.getElementById('terminal-input') as HTMLInputElement;
const outputEl = document.getElementById('terminal-output') as HTMLDivElement;

// ── Clock ─────────────────────────────────────────────────────────────────────

function updateClock() {
  const el = document.getElementById('tui-clock');
  if (!el) return;
  const now = new Date();
  let h = now.getHours();
  const m = now.getMinutes().toString().padStart(2, '0');
  const ampm = h >= 12 ? 'pm' : 'am';
  h = h % 12 || 12;
  el.textContent = `${h}:${m}${ampm}`;
}

updateClock();
setInterval(updateClock, 10000);

// ── Init ──────────────────────────────────────────────────────────────────────

async function init() {
  try {
    const res = await fetch('/glitch-db.json');
    db = await res.json() as GlitchDB;
    fuse = new Fuse(db.qa, {
      keys: [
        { name: 'question', weight: 0.7 },
        { name: 'keywords', weight: 0.3 },
      ],
      threshold: 0.4,
      includeScore: true,
    });
  } catch {
    appendLine('output-error', 'Could not load response database. Refresh to retry.');
  }

  // Re-focus on terminal click
  document.getElementById('mac-terminal')?.addEventListener('click', () => {
    inputEl.focus();
  });

  // Run intro, then enable input
  inputEl.disabled = true;
  await runIntro();
  inputEl.disabled = false;
  inputEl.addEventListener('keydown', handleKey);
  inputEl.focus();
}

// ── Input handling ─────────────────────────────────────────────────────────────

function handleKey(e: KeyboardEvent) {
  switch (e.key) {
    case 'Enter': {
      const cmd = inputEl.value.trim();
      inputEl.value = '';
      if (!cmd) return;
      history.unshift(cmd);
      historyIdx = -1;
      appendLine('output-cmd', `>> ${cmd}`);
      processCommand(cmd);
      break;
    }
    case 'ArrowUp':
      e.preventDefault();
      if (historyIdx < history.length - 1) {
        historyIdx++;
        inputEl.value = history[historyIdx];
      }
      break;
    case 'ArrowDown':
      e.preventDefault();
      if (historyIdx > 0) {
        historyIdx--;
        inputEl.value = history[historyIdx];
      } else {
        historyIdx = -1;
        inputEl.value = '';
      }
      break;
    case 'Tab':
      e.preventDefault();
      tabComplete();
      break;
    case 'l':
      if (e.ctrlKey) { e.preventDefault(); clearTerminal(); }
      break;
  }
}

// ── Command dispatch ──────────────────────────────────────────────────────────

function processCommand(raw: string) {
  if (!db) {
    appendLine('output-error', 'Database not loaded. Refresh to retry.');
    return;
  }

  if (raw.startsWith('/')) {
    const name = raw.slice(1).toLowerCase().trim();

    if (name === 'clear' || name === 'c') {
      clearTerminal();
      return;
    }

    if (name === 'help' || name === 'h' || name === '?') {
      typewrite(db.commands['help'] ?? 'Type /install, /pipelines, or /brain to get started.');
      return;
    }

    if (name === 'install') {
      showInstall();
      return;
    }

    if (name === 'screenshots' || name === 'ss') {
      openScreenshots();
      return;
    }

    if (name === 'docs' || name === 'd') {
      if ((window as any).DOCS_PANEL) {
        (window as any).DOCS_PANEL.open();
      } else {
        window.location.href = '/docs';
      }
      return;
    }

    if (name === 'pipelines' || name === 'pipeline') {
      showRandomPipeline();
      return;
    }

    if (db.commands[name]) {
      typewrite(db.commands[name]);
      return;
    }

    appendLine('output-error', `/${name}: command not found. Type /help for a list.`);
    return;
  }

  // Freeform fuzzy search
  if (fuse) {
    const results = fuse.search(raw);
    if (results.length > 0 && (results[0].score ?? 1) < 0.5) {
      typewrite(results[0].item.response);
      return;
    }
  }

  appendLine('output-dim', `No response found for that. Try /help.`);
}

// ── Install command ───────────────────────────────────────────────────────────

interface ReleaseData {
  version: string;
  repo: string;
  assets: Record<string, string>;
}

async function detectPlatform(): Promise<{ os: string; arch: string }> {
  const ua  = navigator.userAgent.toLowerCase();
  const pf  = (navigator.platform ?? '').toLowerCase();

  let os   = 'linux';
  let arch = 'amd64';

  if (pf.includes('mac') || ua.includes('macintosh')) {
    os = 'darwin';
  } else if (pf.includes('win') || ua.includes('windows')) {
    os = 'windows';
  }

  // Try the modern high-entropy UA API first (Chrome/Edge)
  try {
    const uaData = (navigator as any).userAgentData;
    if (uaData?.getHighEntropyValues) {
      const hints = await uaData.getHighEntropyValues(['architecture']);
      if (hints.architecture === 'arm') arch = 'arm64';
    }
  } catch { /* ignore */ }

  // Fallback heuristics
  if (arch === 'amd64') {
    if (ua.includes('arm64') || ua.includes('aarch64')) arch = 'arm64';
  }

  return { os, arch };
}

async function showInstall() {
  appendLine('output-dim', 'detecting platform...');

  let rel: ReleaseData | null = null;
  try {
    const res = await fetch('/release.json');
    const data = await res.json() as ReleaseData;
    if (data.version) rel = data;
  } catch { /* no release yet */ }

  const { os, arch } = await detectPlatform();

  if (!rel || !rel.version) {
    // No release published yet — show brew as primary
    typewrite(
      'Install via Homebrew (recommended):\n\n' +
      '  brew install 8op-org/tap/glitch\n\n' +
      'Or build from source:\n\n' +
      '  go install github.com/8op-org/gl1tch/cmd/glitch@latest\n\n' +
      'Then pull a local model:\n\n' +
      '  ollama pull qwen2.5-coder:latest\n\n' +
      'Run `glitch`. That\'s it.'
    );
    return;
  }

  const key = `${os}_${arch}`;
  const url = rel.assets[key] ?? '';
  const version = rel.version;
  const isWindows = os === 'windows';

  let lines = `GLITCH ${version}\n\n`;

  if (isWindows) {
    // Windows: show WSL2 (recommended) and native options
    const linuxUrl = rel.assets['linux_amd64'] ?? '';
    lines += `Windows detected.\n\n`;
    lines += `WSL2 (recommended — full tmux experience):\n`;
    if (linuxUrl) {
      lines += `  curl -L "${linuxUrl}" | tar xz -C /tmp/glitch-install\n`;
      lines += `  cd /tmp/glitch-install && ./install.sh\n`;
    }
    lines += `\nNative Windows:\n`;
    if (url) {
      lines += `  Download: ${url}\n`;
      lines += `  Extract the zip and run install.sh in PowerShell.\n`;
    }
    lines += `\nWSL2 gives you the full experience. tmux required.`;
  } else {
    const label = os === 'darwin'
      ? (arch === 'arm64' ? 'macOS — Apple Silicon' : 'macOS — Intel')
      : (arch === 'arm64' ? 'Linux — ARM64' : 'Linux — x86_64');

    lines += `${label}\n\n`;
    if (os === 'darwin') {
      lines += `  brew install 8op-org/tap/glitch\n\n`;
      lines += `Or download the binary directly:\n\n`;
    }
    if (url) {
      lines += `  curl -L "${url}" | tar xz -C /tmp/glitch-install\n`;
      lines += `  cd /tmp/glitch-install && ./install.sh\n\n`;
    }
    lines += `Make sure ~/.local/bin is on your $PATH.\n\n`;

    // Offer the other arch too
    const otherArch  = arch === 'arm64' ? 'amd64' : 'arm64';
    const otherLabel = os === 'darwin'
      ? (otherArch === 'arm64' ? 'Apple Silicon' : 'Intel')
      : (otherArch === 'arm64' ? 'ARM64' : 'x86_64');
    const otherUrl   = rel.assets[`${os}_${otherArch}`] ?? '';
    if (otherUrl) {
      lines += `Wrong arch? ${otherLabel}: ${otherUrl}`;
    }
  }

  typewrite(lines);
}

// ── Screenshots gallery ───────────────────────────────────────────────────────

interface Screenshot {
  name: string;
  file: string;
  caption: string;
}

let galleryEl: HTMLDivElement | null = null;
let galleryIdx = 0;
let galleryShots: Screenshot[] = [];

async function openScreenshots() {
  let shots: Screenshot[] = [];
  try {
    const res = await fetch('/screenshots/index.json');
    shots = await res.json() as Screenshot[];
  } catch {
    appendLine('output-error', 'Could not load screenshots. Run tools/screenshots/take.sh first.');
    return;
  }
  if (shots.length === 0) {
    appendLine('output-dim', 'No screenshots yet. Run: tools/screenshots/take.sh');
    return;
  }
  galleryShots = shots;
  galleryIdx = 0;
  if (galleryEl) galleryEl.remove();
  galleryEl = document.createElement('div');
  galleryEl.className = 'output-line screenshot-gallery';
  galleryEl.setAttribute('tabindex', '0');
  outputEl.appendChild(galleryEl);
  scrollBottom();
  renderGallery();
  galleryEl.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'ArrowRight' || e.key === 'l') {
      e.preventDefault();
      galleryIdx = (galleryIdx + 1) % galleryShots.length;
      renderGallery();
    } else if (e.key === 'ArrowLeft' || e.key === 'h') {
      e.preventDefault();
      galleryIdx = (galleryIdx - 1 + galleryShots.length) % galleryShots.length;
      renderGallery();
    } else if (e.key === 'Escape' || e.key === 'q') {
      e.preventDefault();
      closeGallery();
      inputEl.focus();
    }
  });
  galleryEl.focus();
}

function renderGallery() {
  if (!galleryEl || galleryShots.length === 0) return;
  const shot = galleryShots[galleryIdx];
  // Clear previous content
  while (galleryEl.firstChild) galleryEl.removeChild(galleryEl.firstChild);

  // Header
  const header = document.createElement('div');
  header.className = 'sg-header';
  const counter = document.createElement('span');
  counter.className = 'sg-counter';
  counter.textContent = `[${galleryIdx + 1}/${galleryShots.length}]`;
  const caption = document.createElement('span');
  caption.className = 'sg-caption';
  caption.textContent = shot.caption;
  const keys = document.createElement('span');
  keys.className = 'sg-keys';
  keys.textContent = '← → navigate · esc close';
  header.appendChild(counter);
  header.appendChild(caption);
  header.appendChild(keys);

  // Image — sanitize filename to prevent path traversal
  const imgWrap = document.createElement('div');
  imgWrap.className = 'sg-img-wrap';
  const img = document.createElement('img');
  img.className = 'sg-img';
  img.setAttribute('loading', 'lazy');
  img.src = `/screenshots/${shot.file.replace(/[^a-zA-Z0-9._-]/g, '')}`;
  img.alt = shot.caption;
  imgWrap.appendChild(img);

  // Dots
  const dots = document.createElement('div');
  dots.className = 'sg-dots';
  galleryShots.forEach((_, i) => {
    const dot = document.createElement('span');
    dot.className = i === galleryIdx ? 'sg-dot sg-dot-active' : 'sg-dot';
    dots.appendChild(dot);
  });

  galleryEl.appendChild(header);
  galleryEl.appendChild(imgWrap);
  galleryEl.appendChild(dots);
}

function closeGallery() {
  if (galleryEl) { galleryEl.remove(); galleryEl = null; }
}

// ── Random pipeline examples ─────────────────────────────────

const PIPELINES = [
  {
    name: 'code-review',
    desc: 'local model reads the diff, cloud model judges it',
    yaml: `name: code-review
version: "1"

steps:
  - id: read
    plugin: ollama
    model: qwen2.5-coder:latest
    prompt: |
      Summarize what changed in this diff: {{input}}
      Be specific. List files touched and intent.

  - id: review
    executor: claude
    model: claude-haiku-4-5-20251001
    needs: [read]
    prompt: |
      {{steps.read.output}}
      Flag bugs, security issues, or patterns that look wrong.`,
  },
  {
    name: 'morning-standup',
    desc: 'summarize yesterday\'s commits into a standup update',
    yaml: `name: morning-standup
version: "1"

steps:
  - id: commits
    plugin: sh
    vars:
      cmd: "git log --oneline --since=yesterday"

  - id: standup
    executor: claude
    model: claude-haiku-4-5-20251001
    prompt: |
      Commits from yesterday:
      {{steps.commits.output}}

      Write a 3-sentence standup update.
      What was done. Any blockers. What's next.`,
  },
  {
    name: 'gh-triage',
    desc: 'pull open issues and prioritize them by impact',
    yaml: `name: gh-triage
version: "1"

steps:
  - id: issues
    plugin: gh
    vars:
      args: "issue list --json number,title,labels --limit 20"

  - id: triage
    executor: claude
    model: claude-sonnet-4-6
    needs: [issues]
    prompt: |
      Open issues:
      {{steps.issues.output}}

      Rank by impact. Flag anything blocking a release.
      Output as a numbered list with one-line rationale each.`,
  },
  {
    name: 'brain-map',
    desc: 'index the codebase architecture into brain context',
    yaml: `name: brain-map
version: "1"

steps:
  - id: scan
    plugin: sh
    vars:
      cmd: "find . -name '*.go' | head -30 | xargs head -5"

  - id: map
    plugin: ollama
    model: qwen2.5-coder:latest
    needs: [scan]
    prompt: |
      Source files:
      {{steps.scan.output}}

      Write a concise architecture map.
      Packages, responsibilities, key patterns.
      Start with "ARCHITECTURE:"`,
  },
  {
    name: 'doc-gen',
    desc: 'generate godoc comments for undocumented functions',
    yaml: `name: doc-gen
version: "1"

steps:
  - id: read
    plugin: sh
    vars:
      cmd: "grep -n 'func ' {{input}} | head -20"

  - id: docs
    executor: claude
    model: claude-haiku-4-5-20251001
    prompt: |
      Functions in {{input}}:
      {{steps.read.output}}

      Write godoc comments for each exported function.
      Follow standard Go doc conventions.`,
  },
  {
    name: 'security-scan',
    desc: 'scan code for common vulnerabilities',
    yaml: `name: security-scan
version: "1"

steps:
  - id: read
    plugin: sh
    vars:
      cmd: "cat {{input}}"

  - id: scan
    executor: claude
    model: claude-sonnet-4-6
    prompt: |
      Code:
      {{steps.read.output}}

      Check for: SQL injection, command injection, hardcoded secrets,
      insecure deserialization, path traversal, missing auth checks.
      Report findings with line references.`,
  },
  {
    name: 'changelog-draft',
    desc: 'draft a changelog entry from recent commits',
    yaml: `name: changelog-draft
version: "1"

steps:
  - id: log
    plugin: sh
    vars:
      cmd: "git log --oneline v{{input}}..HEAD"

  - id: draft
    executor: claude
    model: claude-haiku-4-5-20251001
    prompt: |
      Commits since last release:
      {{steps.log.output}}

      Draft a changelog entry in Keep a Changelog format.
      Group into: Added, Changed, Fixed, Removed.`,
  },
];

function showRandomPipeline() {
  const pick = PIPELINES[Math.floor(Math.random() * PIPELINES.length)];
  typewrite(`${pick.name}  —  ${pick.desc}\n\n${pick.yaml}\n\nrun it:  glitch pipeline run ${pick.name}.yaml\ntype /pipelines again for another example.`);
}

// ── Output ────────────────────────────────────────────────────────────────────

function appendLine(cls: string, text: string) {
  const div = document.createElement('div');
  div.className = `output-line ${cls}`;
  div.textContent = text;
  outputEl.appendChild(div);
  scrollBottom();
}

let twTimer: ReturnType<typeof setTimeout> | null = null;

function sleep(ms: number) {
  return new Promise<void>(r => setTimeout(r, ms));
}

function typewrite(text: string): Promise<void> {
  if (twTimer) { clearTimeout(twTimer); twTimer = null; }

  const div = document.createElement('div');
  div.className = 'output-line output-response';
  outputEl.appendChild(div);
  scrollBottom();

  return new Promise<void>(resolve => {
    let i = 0;
    function tick() {
      if (i < text.length) {
        div.textContent = text.slice(0, i + 1);
        i++;
        const ch = text[i - 1];
        const delay = ch === '\n' ? 8 : ch === '.' || ch === ':' ? 8 : 3;
        twTimer = setTimeout(tick, delay);
        scrollBottom();
      } else {
        resolve();
      }
    }
    tick();
  });
}

// ── Intro sequence ────────────────────────────────────────────────────────────

async function runIntro() {
  appendLine('output-dim', 'gl1tch ready.');
}

function clearTerminal() {
  while (outputEl.firstChild) outputEl.removeChild(outputEl.firstChild);
}

function tabComplete() {
  if (!db || !inputEl.value.startsWith('/')) return;
  const partial = inputEl.value.slice(1).toLowerCase();
  const allCmds = [...Object.keys(db.commands), 'screenshots', 'clear', 'docs'];
  const matches = allCmds.filter(c => c.startsWith(partial));
  if (matches.length === 1) {
    inputEl.value = `/${matches[0]}`;
  } else if (matches.length > 1) {
    appendLine('output-dim', matches.map(m => `/${m}`).join('  '));
  }
}

function scrollBottom() {
  outputEl.scrollTop = outputEl.scrollHeight;
}

// ── Hex canvas background ─────────────────────────────────────────────────────

function initHexCanvas() {
  const canvas = document.getElementById('hexbg') as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  const COL_W = 28;
  const ROW_H = 18;
  let COLS: number, ROWS: number;
  let offsets: number[], speeds: number[], grid: string[][];
  let animId: number;

  function hexByte() {
    return Math.floor(Math.random() * 256).toString(16).padStart(2, '0').toUpperCase();
  }

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }

  function setup() {
    COLS = Math.ceil(canvas.width  / COL_W) + 2;
    ROWS = Math.ceil(canvas.height / ROW_H) + 3;
    offsets = Array.from({ length: COLS }, () => Math.random() * ROWS * ROW_H);
    speeds  = Array.from({ length: COLS }, () => 0.25 + Math.random() * 0.45);
    const GRID_H = ROWS * 4;
    grid = Array.from({ length: GRID_H }, () =>
      Array.from({ length: COLS }, hexByte)
    );
  }

  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.font      = '12px "JetBrains Mono", monospace';
    ctx.fillStyle = 'rgba(135, 135, 175, 0.07)';

    for (let col = 0; col < COLS; col++) {
      offsets[col] = (offsets[col] + speeds[col]) % (grid.length * ROW_H);
      const startRow = Math.floor(offsets[col] / ROW_H);
      const subPx    = offsets[col] % ROW_H;
      for (let row = 0; row <= ROWS + 1; row++) {
        const y       = row * ROW_H - subPx;
        const gridRow = (startRow + row) % grid.length;
        ctx.fillText(grid[gridRow][col], col * COL_W, y);
      }
    }
    animId = requestAnimationFrame(draw);
  }

  resize();
  setup();
  window.addEventListener('resize', () => { resize(); setup(); });
  draw();
}

// ── Boot ──────────────────────────────────────────────────────────────────────

document.addEventListener('DOMContentLoaded', () => {
  initHexCanvas();
  init();
});
</script>

<style>
  /* ── TUI color palette ──────────────────────────────────────── */
  :root {
    --tui-bg:        #1a1b26;
    --tui-border:    #3d7a8a;
    --tui-statusbg:  #0f1017;
    --tui-yellow:    #e0af68;
    --tui-cyan:      #7dcfff;
    --tui-dim:       #565f89;
    --tui-fg:        #c0caf5;
  }

  /* ── Outer wrapper ──────────────────────────────────────────── */
  .tui-terminal {
    display: flex;
    flex-direction: row;
    width: 100%;
    height: 100%;
    min-height: 0;
    flex: 1;
    background: var(--tui-bg);
    font-family: 'JetBrains Mono', 'Courier New', monospace;
    font-size: 13px;
    color: var(--tui-fg);
    position: relative;
    overflow: hidden;
  }

  /* ── Left pane border (2px teal bar) ───────────────────────── */
  .tui-pane-bar {
    flex: 0 0 2px;
    background: var(--tui-border);
    height: 100%;
  }

  /* ── Main content column ────────────────────────────────────── */
  .tui-main {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
  }

  /* ── Logo area ──────────────────────────────────────────────── */
  .tui-logo-area {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px 0 12px;
  }

  .tui-logo {
    max-width: 420px;
    width: 60%;
    height: auto;
