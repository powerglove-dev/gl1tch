---
import DocsLayout from '../layouts/DocsLayout.astro';

const providers = [
  {
    id: 'ollama',
    name: 'ollama',
    binary: 'glitch-ollama',
    description: 'Run any local model via Ollama. Ships with gl1tch — the default provider for all internal ops.',
    models: 'any model pulled to Ollama',
    accentColor: 'var(--green)',
    docsUrl: 'https://ollama.com',
  },
  {
    id: 'claude',
    name: 'claude',
    binary: 'glitch-claude',
    description: 'Claude AI assistant via the claude CLI.',
    models: 'opus-4-6 · sonnet-4-6 · haiku-4-5',
    accentColor: 'var(--purple)',
    docsUrl: 'https://claude.ai/code',
  },
  {
    id: 'gemini',
    name: 'gemini',
    binary: 'glitch-gemini',
    description: 'Google Gemini via the gemini CLI.',
    models: '2.5-pro · 2.5-flash · 2.0-flash · 1.5-pro',
    accentColor: 'var(--cyan)',
    docsUrl: 'https://ai.google.dev/gemini-api/docs/gemini-cli',
  },
  {
    id: 'codex',
    name: 'codex',
    binary: 'glitch-codex',
    description: 'OpenAI Codex coding agent.',
    models: 'codex-mini-latest · o4-mini · o3',
    accentColor: 'var(--orange)',
    docsUrl: 'https://github.com/openai/codex',
  },
  {
    id: 'github-copilot',
    name: 'github-copilot',
    binary: 'glitch-github-copilot',
    description: 'GitHub Copilot suggestions via the gh CLI.',
    models: null,
    accentColor: 'var(--yellow)',
    docsUrl: 'https://cli.github.com',
  },
  {
    id: 'opencode',
    name: 'opencode',
    binary: 'glitch-opencode',
    description: 'Agentic AI coding via opencode. Pairs with any provider/model string.',
    models: 'any provider/model (e.g. ollama/llama3.2)',
    accentColor: 'var(--pink)',
    docsUrl: 'https://opencode.ai',
  },
];

const community = [
  {
    id: 'gl1tch-weather',
    name: 'gl1tch-weather',
    binary: 'glitch-weather',
    description: 'Pull live weather data into your pipelines.',
    install: 'glitch plugin install adam-stokes/gl1tch-weather',
    accentColor: 'var(--cyan)',
  },
  {
    id: 'gl1tch-notify',
    name: 'gl1tch-notify',
    binary: 'glitch-notify',
    description: 'Desktop and push notifications from pipeline steps.',
    install: 'glitch plugin install adam-stokes/gl1tch-notify',
    accentColor: 'var(--yellow)',
  },
  {
    id: 'gl1tch-mud',
    name: 'gl1tch-mud',
    binary: 'glitch-mud',
    description: 'Text MUD world executor — run procedural world generation pipelines.',
    install: 'glitch plugin install adam-stokes/gl1tch-mud',
    accentColor: 'var(--green)',
  },
];
---
<DocsLayout title="Ecosystem" description="GL1TCH plugin ecosystem — provider plugins, community extensions, and how to build your own.">
  <h1 class="docs-page-title"><span class="fg-purple">&#x250C;&#x2500;</span> ECOSYSTEM</h1>
  <p class="docs-page-desc">
    Provider plugins ship with gl1tch — no install needed.<br/>
    Community plugins install with one command. Build your own with a binary and a YAML manifest.
  </p>

  <!-- Providers -->
  <div class="docs-section-grid">
    <div class="docs-section-title">
      <span class="fg-comment">&#x2502;</span> PROVIDERS
      <span class="fg-comment docs-section-desc">&mdash; bundled, zero install, ready in any pipeline step</span>
    </div>

    <div class="eco-grid">
      {providers.map(p => (
        <div class="eco-card" id={`eco-${p.id}`} style={`border-left-color: ${p.accentColor}`}>
          <div class="eco-card-header">
            <span class="eco-card-name" style={`color: ${p.accentColor}`}>{p.name}</span>
            <span class="eco-card-badge">bundled</span>
          </div>
          <p class="eco-card-desc">{p.description}</p>
          <div class="eco-card-meta">
            <div class="eco-meta-row">
              <span class="eco-meta-key">binary</span>
              <code class="eco-meta-val">{p.binary}</code>
            </div>
            {p.models && (
              <div class="eco-meta-row">
                <span class="eco-meta-key">models</span>
                <span class="eco-meta-val eco-meta-dim">{p.models}</span>
              </div>
            )}
            <div class="eco-meta-row">
              <span class="eco-meta-key">docs</span>
              <a class="eco-meta-val eco-meta-link" href={p.docsUrl} target="_blank" rel="noopener">
                {p.docsUrl.replace(/^https?:\/\//, '')}
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="docs-section-end">
      <span class="fg-comment">&#x2514;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;</span>
    </div>
  </div>

  <!-- Community -->
  <div class="docs-section-grid">
    <div class="docs-section-title">
      <span class="fg-comment">&#x2502;</span> COMMUNITY
      <span class="fg-comment docs-section-desc">&mdash; install any GitHub-hosted plugin with one command</span>
    </div>

    <div class="eco-grid">
      {community.map(p => (
        <div class="eco-card" id={`eco-${p.id}`} style={`border-left-color: ${p.accentColor}`}>
          <div class="eco-card-header">
            <span class="eco-card-name" style={`color: ${p.accentColor}`}>{p.name}</span>
            <span class="eco-card-badge eco-card-badge-install">installable</span>
          </div>
          <p class="eco-card-desc">{p.description}</p>
          <div class="eco-card-meta">
            <div class="eco-meta-row">
              <span class="eco-meta-key">binary</span>
              <code class="eco-meta-val">{p.binary}</code>
            </div>
            <div class="eco-meta-row">
              <span class="eco-meta-key">install</span>
              <code class="eco-meta-val eco-install-cmd">{p.install}</code>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="eco-build-note fg-comment">
      Any repo with a <code>glitch-plugin.yaml</code> at its root is installable via <code>glitch plugin install owner/repo</code>.
    </div>

    <div class="docs-section-end">
      <span class="fg-comment">&#x2514;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;&#x2500;</span>
    </div>
  </div>
</DocsLayout>

<style>
.eco-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  gap: 10px;
  margin-bottom: 16px;
}

.eco-card {
  border: 1px solid var(--current-line);
  border-left-width: 2px;
  padding: 14px 16px;
  font-family: 'JetBrains Mono', monospace;
  transition: background 0.12s;
}
.eco-card:hover { background: rgba(255,255,255,0.02); }

.eco-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
}

.eco-card-name {
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 0.04em;
}

.eco-card-badge {
  font-size: 8px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border: 1px solid var(--current-line);
  color: var(--comment);
  padding: 1px 5px;
}
.eco-card-badge-install {
  border-color: var(--cyan);
  color: var(--cyan);
}

.eco-card-desc {
  font-size: 11px;
  line-height: 1.6;
  color: var(--comment);
  margin: 0 0 10px;
}

.eco-card-meta { display: flex; flex-direction: column; gap: 3px; }

.eco-meta-row {
  display: flex;
  gap: 10px;
  font-size: 10.5px;
  line-height: 1.5;
}

.eco-meta-key {
  min-width: 46px;
  flex-shrink: 0;
  color: var(--comment);
  font-size: 9.5px;
  letter-spacing: 0.04em;
  padding-top: 1px;
}

.eco-meta-val {
  color: var(--fg);
  font-family: 'JetBrains Mono', monospace;
  font-size: 10.5px;
}

.eco-meta-dim { color: var(--comment); }

.eco-meta-link {
  color: var(--purple);
  text-decoration: none;
  border-bottom: 1px solid rgba(135,135,175,0.25);
  font-size: 10px;
}
.eco-meta-link:hover { color: var(--cyan); border-bottom-color: var(--cyan); }

.eco-install-cmd { color: var(--cyan); }

.eco-build-note {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  line-height: 1.6;
  margin: 0 0 16px;
}
.eco-build-note code {
  color: var(--cyan);
  font-family: inherit;
}

@media (max-width: 640px) {
  .eco-grid { grid-template-columns: 1fr; }
}
</style>
