---
import DocsLayout from '../../../layouts/DocsLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const docs = (await getCollection('pipelines')).sort((a, b) => a.data.order - b.data.order);

  return docs.map((doc, index) => {
    const prev = index > 0 ? docs[index - 1] : null;
    const next = index < docs.length - 1 ? docs[index + 1] : null;

    return {
      params: { slug: doc.id },
      props: {
        doc,
        prevDoc: prev ? { slug: prev.id, title: prev.data.title } : null,
        nextDoc: next ? { slug: next.id, title: next.data.title } : null,
      },
    };
  });
}

const { doc, prevDoc, nextDoc } = Astro.props;
const { Content } = await render(doc);
---
<DocsLayout
  title={doc.data.title}
  description={doc.data.description}
  section="pipelines"
  prevDoc={prevDoc}
  nextDoc={nextDoc}
>
  <h1 class="docs-page-title">{doc.data.title}</h1>
  <p class="docs-page-desc">{doc.data.description}</p>

  <div class="docs-article">
    <Content />
  </div>
</DocsLayout>
